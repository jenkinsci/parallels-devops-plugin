<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form" xmlns:c="/lib/credentials">
    <f:entry title="Template Label" field="templateLabel">
        <f:textbox />
    </f:entry>
    <f:entry title="SSH Credentials" field="sshCredentialsId">
        <c:select />
    </f:entry>
    <f:entry title="Agent Workspace Directory" field="agentWorkspaceDir">
        <f:textbox default="/tmp/jenkins-agent"
                   description="Filesystem path for the Jenkins agent workspace on the VM. Override this if your image uses a different writable location." />
    </f:entry>

    <f:entry title="Provisioning Mode" field="provisioningConfig">
        <f:dropdownDescriptorSelector field="provisioningConfig"
                                      descriptors="${descriptor.provisioningConfigDescriptors}" />
    </f:entry>

    <f:entry title="Number of Executors" field="numExecutors">
        <f:number default="1" min="1" />
    </f:entry>
    <f:entry title="VM Ready Timeout (s)" field="vmReadyTimeoutSeconds">
        <f:number default="300" min="30" description="How long to wait (in seconds) for the VM to reach running state before failing." />
    </f:entry>
    <f:entry title="VM Ready Poll Interval (s)" field="vmReadyPollIntervalSeconds">
        <f:number default="10" min="5" description="How often (in seconds) to poll the prl-devops-service for VM status while waiting for it to start." />
    </f:entry>
</j:jelly>

